+name: Release
+
+on:
+  push:
+    tags:
+      - "v*.*.*"
+  workflow_dispatch:
+    inputs:
+      dry_run:
+        description: "Build and validate but do not publish"
+        required: false
+        default: "true"
+        type: choice
+        options: ["true", "false"]
+
+permissions:
+  contents: write   # create GitHub Releases
+  id-token: write   # for future OIDC publishing
+
+concurrency:
+  group: release-${{ github.ref }}
+  cancel-in-progress: false
+
+jobs:
+  # Re-run the test suite on the tagged commit to guarantee shippability.
+  verify:
+    name: Verify (re-test the tagged commit)
+    runs-on: windows-latest
+    steps:
+      - uses: actions/checkout@v4
+
+      - name: Install Pester + PSScriptAnalyzer
+        shell: pwsh
+        run: |
+          Set-PSRepository -Name PSGallery -InstallationPolicy Trusted
+          Install-Module Pester -MinimumVersion 5.5.0 -Force -SkipPublisherCheck
+          Install-Module PSScriptAnalyzer -Force -SkipPublisherCheck
+
+      - name: Lint
+        shell: pwsh
+        run: |
+          $r = Invoke-ScriptAnalyzer -Path . -Recurse -Settings .\PSScriptAnalyzerSettings.psd1
+          if ($r) { $r | Format-Table | Out-String | Write-Host; exit 1 }
+
+      - name: Test
+        shell: pwsh
+        run: |
+          $c = New-PesterConfiguration
+          $c.Run.Path = 'tests'
+          $c.Run.Exit = $true
+          $c.Run.Throw = $true
+          Invoke-Pester -Configuration $c
+
+  package:
+    name: Package module
+    needs: verify
+    runs-on: windows-latest
+    outputs:
+      version: ${{ steps.ver.outputs.version }}
+      artifact: ${{ steps.pkg.outputs.path }}
+    steps:
+      - uses: actions/checkout@v4
+
+      - name: Derive version
+        id: ver
+        shell: pwsh
+        run: |
+          $tag = "${{ github.ref_name }}"
+          $version = $tag -replace '^v',''
+          $manifestVer = (Test-ModuleManifest .\Git-Sync.psd1).Version.ToString()
+          if ($manifestVer -ne $version) {
+            Write-Host "::error::Tag version '$version' does not match manifest version '$manifestVer'. Update Git-Sync.psd1 ModuleVersion before tagging."
+            exit 1
+          }
+          Write-Host "version=$version"
+          "version=$version" | Out-File -FilePath $env:GITHUB_OUTPUT -Append
+
+      - name: Stage module files
+        shell: pwsh
+        run: |
+          $stage = "Git-Sync"
+          New-Item -ItemType Directory -Force -Path $stage | Out-Null
+          $files = @(
+            'Git-Sync.psm1','Git-Sync.psd1',
+            'README.md','LICENSE','CHANGELOG.md','SECURITY.md'
+          )
+          foreach ($f in $files) { Copy-Item $f -Destination $stage -Force }
+          Get-ChildItem $stage
+
+      - name: Build .zip artifact
+        id: pkg
+        shell: pwsh
+        run: |
+          $version = "${{ steps.ver.outputs.version }}"
+          $zip = "Git-Sync-$version.zip"
+          Compress-Archive -Path .\Git-Sync\* -DestinationPath $zip -Force
+          Get-Item $zip
+          "path=$zip" | Out-File -FilePath $env:GITHUB_OUTPUT -Append
+
+      - name: Upload artifact
+        uses: actions/upload-artifact@v4
+        with:
+          name: git-sync-module
+          path: |
+            Git-Sync-*.zip
+            Git-Sync/
+          retention-days: 30
+
+  github-release:
+    name: GitHub Release
+    needs: [verify, package]
+    runs-on: ubuntu-latest
+    if: github.event_name == 'push'
+    steps:
+      - uses: actions/checkout@v4
+        with:
+          fetch-depth: 0
+
+      - name: Download artifact
+        uses: actions/download-artifact@v4
+        with:
+          name: git-sync-module
+          path: dist/
+
+      - name: Extract release notes from CHANGELOG
+        id: notes
+        run: |
+          VERSION="${{ needs.package.outputs.version }}"
+          # Pull the section between "## [VERSION]" and the next "## ["
+          awk -v ver="$VERSION" '
+            $0 ~ "^## \\["ver"\\]" {flag=1; next}
+            flag && /^## \[/ {flag=0}
+            flag {print}
+          ' CHANGELOG.md > release_notes.md
+          if [ ! -s release_notes.md ]; then
+            echo "No CHANGELOG entry found for $VERSION — using auto-generated notes." > release_notes.md
+          fi
+          echo "--- release notes ---"
+          cat release_notes.md
+
+      - name: Create GitHub Release
+        uses: softprops/action-gh-release@v2
+        with:
+          tag_name: ${{ github.ref_name }}
+          name: "Git-Sync ${{ needs.package.outputs.version }}"
+          body_path: release_notes.md
+          draft: false
+          prerelease: ${{ contains(github.ref_name, '-') }}
+          generate_release_notes: true
+          files: |
+            dist/Git-Sync-*.zip
+
+  publish-psgallery:
+    name: Publish to PowerShell Gallery
+    needs: [verify, package, github-release]
+    runs-on: windows-latest
+    if: github.event_name == 'push' && !contains(github.ref_name, '-')
+    environment:
+      name: powershell-gallery
+      url: https://www.powershellgallery.com/packages/Git-Sync
+    steps:
+      - uses: actions/checkout@v4
+
+      - name: Download artifact
+        uses: actions/download-artifact@v4
+        with:
+          name: git-sync-module
+          path: dist/
+
+      - name: Publish module
+        shell: pwsh
+        env:
+          NUGET_API_KEY: ${{ secrets.NUGET_API_KEY }}
+        run: |
+          if (-not $env:NUGET_API_KEY) {
+            Write-Host "::warning::NUGET_API_KEY secret is not configured — skipping PowerShell Gallery publish."
+            exit 0
+          }
+          Publish-Module -Path .\dist\Git-Sync -NuGetApiKey $env:NUGET_API_KEY -Repository PSGallery -Verbose
+          Write-Host "::notice::Published Git-Sync $((Test-ModuleManifest .\dist\Git-Sync\Git-Sync.psd1).Version) to PowerShell Gallery ✅"
