+# EditorConfig is awesome: https://editorconfig.org
+# Applies consistent whitespace / encoding rules across editors and OSes.
+
+root = true
+
+# --- Defaults for every file --------------------------------------------------
+[*]
+charset = utf-8
+end_of_line = lf
+indent_style = space
+indent_size = 4
+insert_final_newline = true
+trim_trailing_whitespace = true
+max_line_length = 120
+
+# --- PowerShell ---------------------------------------------------------------
+# CRLF on Windows-targeted scripts to match .gitattributes and avoid
+# `Set-AuthenticodeSignature` / parser hiccups on Windows PowerShell 5.1.
+[*.{ps1,psm1,psd1,ps1xml}]
+end_of_line = crlf
+indent_size = 4
+charset = utf-8-bom
+
+# --- Markdown -----------------------------------------------------------------
+# Markdown is sensitive to trailing whitespace (it means a hard line break).
+[*.md]
+trim_trailing_whitespace = false
+max_line_length = off
+
+# --- YAML / JSON --------------------------------------------------------------
+[*.{yml,yaml}]
+indent_size = 2
+
+[*.json]
+indent_size = 2
+
+# --- Shell scripts ------------------------------------------------------------
+[*.sh]
+end_of_line = lf
+indent_size = 2
+
+# --- Makefile ----------------------------------------------------------------
+[Makefile]
+indent_style = tab
