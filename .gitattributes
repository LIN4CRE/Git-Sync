# Auto detect text files and normalize line endings to LF on checkout
* text=auto

# PowerShell scripts should have CRLF line endings on Windows
*.ps1 text eol=crlf
*.psm1 text eol=crlf
*.psd1 text eol=crlf

# Markdown files should be normalized to LF
*.md text eol=lf

# YAML files should be normalized to LF
*.yml text eol=lf
*.yaml text eol=lf

# Treat binary files as binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
